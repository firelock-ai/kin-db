{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SemanticChange",
  "description": "Kin's native commit — the unit of semantic history.",
  "type": "object",
  "required": [
    "artifact_deltas",
    "author",
    "entity_deltas",
    "evidence",
    "id",
    "message",
    "parents",
    "projected_files",
    "relation_deltas",
    "timestamp"
  ],
  "properties": {
    "artifact_deltas": {
      "description": "Non-entity file changes.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/ArtifactDelta"
      }
    },
    "author": {
      "description": "Human or assistant.",
      "allOf": [
        {
          "$ref": "#/definitions/AuthorId"
        }
      ]
    },
    "authored_on": {
      "description": "Informational: branch name at creation time.",
      "anyOf": [
        {
          "$ref": "#/definitions/BranchName"
        },
        {
          "type": "null"
        }
      ]
    },
    "entity_deltas": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EntityDelta"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EvidenceId"
      }
    },
    "id": {
      "description": "Content-addressed hash.",
      "allOf": [
        {
          "$ref": "#/definitions/SemanticChangeId"
        }
      ]
    },
    "message": {
      "type": "string"
    },
    "parents": {
      "description": "0 = genesis, 1 = normal, 2 = merge.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/SemanticChangeId"
      }
    },
    "projected_files": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/FilePathId"
      }
    },
    "relation_deltas": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RelationDelta"
      }
    },
    "risk_summary": {
      "anyOf": [
        {
          "$ref": "#/definitions/RiskSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "spec_link": {
      "anyOf": [
        {
          "$ref": "#/definitions/SpecId"
        },
        {
          "type": "null"
        }
      ]
    },
    "timestamp": {
      "$ref": "#/definitions/Timestamp"
    }
  },
  "definitions": {
    "ArtifactDelta": {
      "description": "Delta for a non-entity file within a SemanticChange.",
      "type": "object",
      "required": [
        "file_id",
        "kind"
      ],
      "properties": {
        "file_id": {
          "$ref": "#/definitions/FilePathId"
        },
        "kind": {
          "$ref": "#/definitions/ArtifactDeltaKind"
        },
        "new_hash": {
          "anyOf": [
            {
              "$ref": "#/definitions/Hash256"
            },
            {
              "type": "null"
            }
          ]
        },
        "old_hash": {
          "anyOf": [
            {
              "$ref": "#/definitions/Hash256"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "ArtifactDeltaKind": {
      "description": "Classification of an artifact delta.",
      "type": "string",
      "enum": [
        "Added",
        "Modified",
        "Removed"
      ]
    },
    "AuthorId": {
      "description": "Author identifier (human or assistant).",
      "type": "string"
    },
    "BranchName": {
      "description": "Branch name.",
      "type": "string"
    },
    "Entity": {
      "description": "The atomic semantic unit in Kin's graph.",
      "type": "object",
      "required": [
        "fingerprint",
        "id",
        "kind",
        "language",
        "metadata",
        "name",
        "signature",
        "visibility"
      ],
      "properties": {
        "created_in": {
          "description": "None while in overlay; set on kin commit.",
          "anyOf": [
            {
              "$ref": "#/definitions/SemanticChangeId"
            },
            {
              "type": "null"
            }
          ]
        },
        "doc_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "file_origin": {
          "description": "None for graph-created entities before placement.",
          "anyOf": [
            {
              "$ref": "#/definitions/FilePathId"
            },
            {
              "type": "null"
            }
          ]
        },
        "fingerprint": {
          "$ref": "#/definitions/SemanticFingerprint"
        },
        "id": {
          "$ref": "#/definitions/EntityId"
        },
        "kind": {
          "$ref": "#/definitions/EntityKind"
        },
        "language": {
          "$ref": "#/definitions/LanguageId"
        },
        "lineage_parent": {
          "anyOf": [
            {
              "$ref": "#/definitions/EntityId"
            },
            {
              "type": "null"
            }
          ]
        },
        "metadata": {
          "$ref": "#/definitions/EntityMetadata"
        },
        "name": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        },
        "span": {
          "description": "None until projection assigns a file location.",
          "anyOf": [
            {
              "$ref": "#/definitions/SourceSpan"
            },
            {
              "type": "null"
            }
          ]
        },
        "superseded_by": {
          "anyOf": [
            {
              "$ref": "#/definitions/EntityId"
            },
            {
              "type": "null"
            }
          ]
        },
        "visibility": {
          "$ref": "#/definitions/Visibility"
        }
      }
    },
    "EntityDelta": {
      "description": "Delta for a single entity within a SemanticChange.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "Added"
          ],
          "properties": {
            "Added": {
              "$ref": "#/definitions/Entity"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "Modified"
          ],
          "properties": {
            "Modified": {
              "type": "object",
              "required": [
                "new",
                "old"
              ],
              "properties": {
                "new": {
                  "$ref": "#/definitions/Entity"
                },
                "old": {
                  "$ref": "#/definitions/Entity"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "Removed"
          ],
          "properties": {
            "Removed": {
              "$ref": "#/definitions/EntityId"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "EntityId": {
      "description": "Unique identifier for an Entity.",
      "type": "string",
      "format": "uuid"
    },
    "EntityKind": {
      "description": "Classification of a semantic entity.",
      "type": "string",
      "enum": [
        "function",
        "class",
        "interface",
        "trait_def",
        "type_alias",
        "module",
        "package",
        "test",
        "schema",
        "api_endpoint",
        "event_contract",
        "file",
        "document_node",
        "method",
        "enum_def",
        "enum_variant",
        "constant",
        "static_var"
      ]
    },
    "EntityMetadata": {
      "description": "Extensible metadata bag for entities.",
      "type": "object",
      "additionalProperties": true
    },
    "EvidenceId": {
      "description": "Unique identifier for an Evidence record.",
      "type": "string",
      "format": "uuid"
    },
    "FilePathId": {
      "description": "File path identifier.",
      "type": "string"
    },
    "FingerprintAlgorithm": {
      "type": "string",
      "enum": [
        "V1TreeSitter"
      ]
    },
    "Hash256": {
      "description": "Content-addressed 256-bit hash. Serializes as a 32-element byte array.",
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "LanguageId": {
      "description": "Supported programming languages (Tier 1).",
      "type": "string",
      "enum": [
        "TypeScript",
        "JavaScript",
        "Python",
        "Go",
        "Java",
        "Rust",
        "C",
        "Cpp",
        "CSharp",
        "Ruby",
        "Php",
        "Swift",
        "Kotlin",
        "Hcl"
      ]
    },
    "Relation": {
      "description": "A typed edge in the semantic graph.",
      "type": "object",
      "required": [
        "confidence",
        "dst",
        "id",
        "kind",
        "origin",
        "src"
      ],
      "properties": {
        "confidence": {
          "description": "Confidence score (0.0 - 1.0).",
          "type": "number",
          "format": "float"
        },
        "created_in": {
          "description": "None while in overlay; set on kin commit.",
          "anyOf": [
            {
              "$ref": "#/definitions/SemanticChangeId"
            },
            {
              "type": "null"
            }
          ]
        },
        "dst": {
          "$ref": "#/definitions/EntityId"
        },
        "id": {
          "$ref": "#/definitions/RelationId"
        },
        "import_source": {
          "description": "For Calls/References edges, the module/package the target was imported from. Enables qualified cross-repo resolution in the spine. e.g., \"requests\" for `from requests import get`, \"kin_db\" for `use kin_db::InMemoryGraph`",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "$ref": "#/definitions/RelationKind"
        },
        "origin": {
          "$ref": "#/definitions/RelationOrigin"
        },
        "src": {
          "$ref": "#/definitions/EntityId"
        }
      }
    },
    "RelationDelta": {
      "description": "Delta for a single relation within a SemanticChange.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "Added"
          ],
          "properties": {
            "Added": {
              "$ref": "#/definitions/Relation"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "Removed"
          ],
          "properties": {
            "Removed": {
              "$ref": "#/definitions/RelationId"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "RelationId": {
      "description": "Unique identifier for a Relation.",
      "type": "string",
      "format": "uuid"
    },
    "RelationKind": {
      "description": "Classification of a relation edge.",
      "type": "string",
      "enum": [
        "Calls",
        "Imports",
        "Contains",
        "References",
        "Implements",
        "Extends",
        "Tests",
        "DependsOn",
        "DefinesContract",
        "ConsumesContract",
        "EmitsEvent",
        "OwnedBy",
        "DocumentedBy"
      ]
    },
    "RelationOrigin": {
      "description": "How a relation was established.",
      "type": "string",
      "enum": [
        "Parsed",
        "Inferred",
        "Manual"
      ]
    },
    "RiskLevel": {
      "description": "Risk classification.",
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "RiskSummary": {
      "description": "Summary of risk associated with a semantic change.",
      "type": "object",
      "required": [
        "breaking_changes",
        "contract_violations",
        "notes",
        "overall_risk",
        "test_coverage_gaps",
        "work_risks"
      ],
      "properties": {
        "breaking_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contract_violations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "overall_risk": {
          "$ref": "#/definitions/RiskLevel"
        },
        "test_coverage_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "work_risks": {
          "description": "Risks related to in-progress work items affected by changes.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "SemanticChangeId": {
      "description": "Content-addressed identifier for a SemanticChange.",
      "allOf": [
        {
          "$ref": "#/definitions/Hash256"
        }
      ]
    },
    "SemanticFingerprint": {
      "description": "Kin's identity moat. Survives renames, moves, formatting.",
      "type": "object",
      "required": [
        "algorithm",
        "ast_hash",
        "behavior_hash",
        "signature_hash",
        "stability_score"
      ],
      "properties": {
        "algorithm": {
          "$ref": "#/definitions/FingerprintAlgorithm"
        },
        "ast_hash": {
          "description": "Normalized AST shape hash.",
          "allOf": [
            {
              "$ref": "#/definitions/Hash256"
            }
          ]
        },
        "behavior_hash": {
          "description": "Control flow + side effects hash.",
          "allOf": [
            {
              "$ref": "#/definitions/Hash256"
            }
          ]
        },
        "signature_hash": {
          "description": "Parameter/return contract hash.",
          "allOf": [
            {
              "$ref": "#/definitions/Hash256"
            }
          ]
        },
        "stability_score": {
          "description": "Confidence in fingerprint stability (0.0 - 1.0).",
          "type": "number",
          "format": "float"
        }
      }
    },
    "SourceSpan": {
      "description": "Source location of an entity within a file.",
      "type": "object",
      "required": [
        "end_byte",
        "end_col",
        "end_line",
        "file",
        "start_byte",
        "start_col",
        "start_line"
      ],
      "properties": {
        "end_byte": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "end_col": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "end_line": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "file": {
          "$ref": "#/definitions/FilePathId"
        },
        "start_byte": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "start_col": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "start_line": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "SpecId": {
      "description": "Unique identifier for a Spec.",
      "type": "string",
      "format": "uuid"
    },
    "Timestamp": {
      "description": "UTC timestamp wrapper.",
      "type": "string",
      "format": "date-time"
    },
    "Visibility": {
      "description": "Visibility of a semantic entity.",
      "type": "string",
      "enum": [
        "Public",
        "Private",
        "Internal",
        "Crate"
      ]
    }
  }
}